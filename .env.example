# Copy to .env and adjust as needed:
#   cp .env.example .env

PROJECT_ID=sharp-leaf-451416-r4
ZONE=europe-west4-a
INSTANCE_NAME=coa-inference-node

# VM hardware (default: V100 16GB)
MACHINE_TYPE=n1-standard-8
GPU_TYPE=nvidia-tesla-v100
GPU_COUNT=1
IMAGE_PROJECT=ubuntu-os-cloud
IMAGE_FAMILY=ubuntu-2204-lts
BOOT_DISK_SIZE=150GB
BOOT_DISK_TYPE=pd-ssd

# EmoKnob paths default in load_env.sh to ~/emoknob and ~/coa-vm

# Upgrade path if V100 OOM (recreate instance with these instead):
# MACHINE_TYPE=g2-standard-8
# GPU_COUNT=
# (G2 machines have L4 GPUs attached; omit --accelerator in create_instance.sh)
